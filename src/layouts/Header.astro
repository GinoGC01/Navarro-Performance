---
// Header.astro
import config from "../config.json";
const lang = config.meta.defaultLang as keyof typeof config.header;
const h = config.header[lang];
---

<nav class="fixed top-0 w-full z-50 border-b-2 border-[#ff5e00]/20 bg-[#0e0e0e]/80 backdrop-blur-xl flex justify-between items-center px-4 md:px-8 py-4 gap-4 shadow-[0_8px_16px_rgba(0,0,0,0.4)]">
  <div class="flex items-center">
    <a href="/" class="text-xl md:text-2xl font-black italic tracking-tighter text-[#ff5e00] whitespace-nowrap">
        {config.meta.brand}
    </a>
  </div>
  
  <div class="flex gap-4 md:gap-8 font-['Space_Grotesk'] font-bold tracking-tighter uppercase items-center">
    <!-- Language Toggle Button -->
    <button
      id="lang-toggle"
      class="text-on-surface-variant border border-outline-variant/40 px-3 py-1.5 text-xs tracking-widest hover:bg-primary hover:text-black hover:border-primary transition-all duration-200 font-black"
    >
      ES
    </button>

    <!-- Enlace oculto en móvil -->
    <a class="hidden md:block text-[#ff5e00] border-b-2 border-[#ff5e00] pb-1 hover:text-white transition-colors text-sm md:text-base" href="/tunning" data-i18n="header.en.tunning" data-i18n-html>{h.tunning}</a>
    
    <a href="/tunning" class="bg-primary text-on-primary-fixed px-3 py-2 md:px-6 md:py-2 font-black text-xs md:text-sm tracking-widest hover:scale-105 transition-transform duration-200 inline-flex items-center justify-center whitespace-nowrap" data-i18n="header.en.bookAppointment">
        {h.bookAppointment}
    </a>
  </div>
</nav>
