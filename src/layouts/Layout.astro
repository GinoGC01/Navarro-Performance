---
// Layout.astro
import config from "../config.json";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
const lang = config.meta.defaultLang;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;700;900&family=Work+Sans:wght@300;400;500;700;900&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0"
    />
    <ClientRouter />
  </head>
  <body>
    <Header />
    <main class="pt-[72px]">
      <slot />
    </main>
    <Footer />

    <!-- ========================================== -->
    <!-- I18N CLIENT-SIDE LANGUAGE SWITCHING ENGINE  -->
    <!-- ========================================== -->
    <script is:inline define:vars={{ config }}>
      (function () {
        const STORAGE_KEY = "navarro-lang";

        function getLang() {
          return localStorage.getItem(STORAGE_KEY) || config.meta.defaultLang;
        }

        function setLang(lang) {
          localStorage.setItem(STORAGE_KEY, lang);
        }

        function applyLanguage(lang) {
          document.documentElement.lang = lang;

          // Update all elements with data-i18n attribute
          document.querySelectorAll("[data-i18n]").forEach((el) => {
            const originalKey = el.getAttribute("data-i18n");
            const parts = originalKey.split(".");

            if (parts.length >= 2) {
              parts[1] = lang;
            }

            let value = config;
            for (const k of parts) {
              if (value && value[k] !== undefined) {
                value = value[k];
              } else {
                return;
              }
            }

            if (typeof value === "string") {
              if (el.hasAttribute("data-i18n-html")) {
                el.innerHTML = value;
              } else {
                el.textContent = value;
              }
            }
          });

          // Update toggle button text - Show CURRENT language
          const toggleBtn = document.getElementById("lang-toggle");
          if (toggleBtn) {
            toggleBtn.textContent = lang.toUpperCase();
          }

          // Update schedule day names
          const schedDays = [
            { en: "Monday", es: "Lunes" },
            { en: "Tuesday", es: "Martes" },
            { en: "Wednesday", es: "Miércoles" },
            { en: "Thursday", es: "Jueves" },
            { en: "Friday", es: "Viernes" },
            { en: "Saturday", es: "Sábado" },
            { en: "Sunday", es: "Domingo" },
          ];
          const closedText = { en: "Closed", es: "Cerrado" };
          const dayEls = document.querySelectorAll("[data-schedule-day]");
          dayEls.forEach((el, i) => {
            if (schedDays[i])
              el.textContent = schedDays[i][lang] || schedDays[i].en;
          });
          const closedEl = document.querySelector("[data-schedule-closed]");
          if (closedEl)
            closedEl.textContent = closedText[lang] || closedText.en;
        }

        // Global event delegation for the toggle button
        document.addEventListener("click", (e) => {
          if (e.target && e.target.id === "lang-toggle") {
            const current = getLang();
            const next = current === "en" ? "es" : "en";
            setLang(next);
            applyLanguage(next);
          }
        });

        function init() {
          const lang = getLang();
          applyLanguage(lang);
        }

        // Run on initial load and after every View Transition
        init();
        document.addEventListener("astro:page-load", init);
      })();
    </script>
  </body>
</html>
