---
// Footer.astro
---

<footer class="bg-[#000000] border-t-4 border-[#1a1919] flex flex-col md:flex-row justify-between items-center px-12 py-16 w-full gap-8">
  <div>
      <div class="text-xl font-black text-white mb-2 uppercase">KINETIC VELOCITY</div>
      <p class="text-[#ff8f70] font-['Space_Grotesk'] uppercase text-xs tracking-[0.2em] mb-4">ENGINEERING ADRENALINE SINCE 2009</p>
      <p class="text-gray-500 font-['Space_Grotesk'] uppercase text-[10px] tracking-[0.2em]">©2024 KINETIC VELOCITY PERFORMANCE. ALL RIGHTS RESERVED. NO LIMITS.</p>
  </div>
  
  <div class="flex gap-12 font-['Space_Grotesk'] uppercase text-xs tracking-[0.2em]">
      <div class="flex flex-col gap-3">
          <a class="text-[#ff8f70]" href="#">PRIVACY POLICY</a>
          <a class="text-gray-500 hover:text-white transition-colors" href="#">TERMS OF SERVICE</a>
      </div>
      <div class="flex flex-col gap-3">
          <a class="text-gray-500 hover:text-white transition-colors" href="#">SHIPPING</a>
          <a class="text-gray-500 hover:text-white transition-colors" href="#">REFUNDS</a>
      </div>
  </div>
  
  <div class="flex gap-4">
      <div class="w-10 h-10 border border-outline flex items-center justify-center hover:bg-primary hover:text-black transition-colors cursor-pointer">
          <span class="material-symbols-outlined text-sm">share</span>
      </div>
      <div class="w-10 h-10 border border-outline flex items-center justify-center hover:bg-primary hover:text-black transition-colors cursor-pointer">
          <span class="material-symbols-outlined text-sm">mail</span>
      </div>
  </div>
</footer>
