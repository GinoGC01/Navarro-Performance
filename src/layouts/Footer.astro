---
// Footer.astro
import config from "../config.json";
const lang = config.meta.defaultLang as keyof typeof config.footer;
const f = config.footer[lang];
---

<footer class="bg-[#000000] border-t-4 border-[#1a1919] flex flex-col md:flex-row justify-between items-center px-6 md:px-12 py-16 w-full gap-8">
  <div>
      <div class="flex items-center gap-3 mb-6">
        <img src={config.images.logo} alt={config.meta.brand} class="h-10 w-auto object-contain" />
        <div class="flex flex-col leading-none">
          <span class="font-headline font-black text-xl tracking-tighter text-white">NAVARRO</span>
          <span class="font-headline font-bold text-[10px] tracking-[0.3em] text-primary">PERFORMANCE</span>
        </div>
      </div>
      <p class="text-primary font-['Space_Grotesk'] uppercase text-xs tracking-[0.2em] mb-4" data-i18n="footer.en.tagline">{f.tagline}</p>
      <p class="text-gray-500 font-['Space_Grotesk'] uppercase text-[10px] tracking-[0.2em]" data-i18n="footer.en.copyright">{f.copyright}</p>
  </div>
  
  <div class="flex gap-12 font-['Space_Grotesk'] uppercase text-xs tracking-[0.2em]">
      <div class="flex flex-col gap-3">
          <a class="text-primary" href="#" data-i18n="footer.en.privacyPolicy">{f.privacyPolicy}</a>
          <a class="text-gray-500 hover:text-white transition-colors" href="#" data-i18n="footer.en.termsOfService">{f.termsOfService}</a>
      </div>
      <div class="flex flex-col gap-3">
          <a class="text-gray-500 hover:text-white transition-colors" href="#" data-i18n="footer.en.shipping">{f.shipping}</a>
          <a class="text-gray-500 hover:text-white transition-colors" href="#" data-i18n="footer.en.refunds">{f.refunds}</a>
      </div>
  </div>
  
  <div class="flex gap-4">
      <div class="w-10 h-10 border border-outline flex items-center justify-center hover:bg-primary hover:text-black transition-colors cursor-pointer">
          <span class="material-symbols-outlined text-sm">share</span>
      </div>
      <div class="w-10 h-10 border border-outline flex items-center justify-center hover:bg-primary hover:text-black transition-colors cursor-pointer">
          <span class="material-symbols-outlined text-sm">mail</span>
      </div>
  </div>
</footer>
