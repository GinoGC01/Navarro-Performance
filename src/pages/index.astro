---
import Layout from "../layouts/Layout.astro";
import config from "../config.json";

const lang = config.meta.defaultLang as keyof typeof config.home;
const page = config.home[lang];
const images = config.images;
---

<Layout title={page.title}>
  <!-- ========================================== -->
  <!-- 1. HERO SECTION                            -->
  <!-- ========================================== -->
  <section
    class="relative h-[921px] flex items-center overflow-hidden grid-bg"
    transition:animate="fade"
  >
    <div
      class="absolute inset-0 bg-gradient-to-r from-black via-black/80 via-black/60 to-black/40 z-10"
    >
    </div>
    <img
      alt="Featured Build: Navarro Performance"
      class="absolute inset-0 w-full h-full object-cover object-center"
      src={images.hero}
    />

    <div class="container mx-auto px-8 relative z-20">
      <div class="max-w-4xl">
        <span
          class="inline-block bg-primary text-on-primary-fixed px-4 py-1 font-black italic mb-6"
          data-i18n="home.en.hero.badge">{page.hero.badge}</span
        >

        <h1
          class="text-4xl sm:text-5xl md:text-9xl font-black tracking-tighter leading-[0.85] md:leading-[0.85] uppercase italic mb-8"
          data-i18n="home.en.hero.heading"
          data-i18n-html
          set:html={page.hero.heading}
        />

        <p
          class="text-base sm:text-lg md:text-2xl font-body text-on-surface-variant max-w-2xl mb-8 md:mb-12 border-l-4 border-primary pl-4 md:pl-6"
          data-i18n="home.en.hero.description"
        >
          {page.hero.description}
        </p>

        <div class="flex flex-col sm:flex-row flex-wrap gap-4 md:gap-6">
          <a
            href="/tunning"
            class="bg-primary text-on-primary-fixed w-full sm:w-auto px-6 py-4 md:px-10 md:py-5 text-sm md:text-xl font-black tracking-tighter uppercase hover:scale-105 transition-transform border-4 border-primary/20 text-center inline-block"
            data-i18n="home.en.hero.ctaPrimary"
          >
            {page.hero.ctaPrimary}
          </a>
          <a
            href="#builds"
            class="bg-surface-container-highest text-on-surface w-full sm:w-auto px-6 py-4 md:px-10 md:py-5 text-sm md:text-xl font-black tracking-tighter uppercase border-l-4 border-primary hover:bg-surface-bright transition-colors text-center inline-block"
            data-i18n="home.en.hero.ctaSecondary"
          >
            {page.hero.ctaSecondary}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========================================== -->
  <!-- 2. STATS SECTION                           -->
  <!-- ========================================== -->
  <section
    class="bg-surface-container-lowest py-20 border-y-4 border-surface-container"
  >
    <div class="container mx-auto px-8">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        {
          page.stats.map((stat: any, i: number) => (
            <div class="bg-surface-container p-6 md:p-10 border-b-8 border-primary group hover:bg-surface-container-high transition-colors">
              <div
                class="text-6xl font-black italic text-white group-hover:text-primary transition-colors"
                data-i18n={`home.en.stats.${i}.value`}
              >
                {stat.value}
              </div>
              <div
                class="font-label text-on-surface-variant tracking-[0.2em] mt-2 uppercase"
                data-i18n={`home.en.stats.${i}.label`}
              >
                {stat.label}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ========================================== -->
  <!-- 3. SERVICES BENTO GRID SECTION             -->
  <!-- ========================================== -->
  <section class="py-24 bg-surface">
    <div class="container mx-auto px-8">
      <div
        class="flex flex-col md:flex-row justify-between items-start md:items-end mb-16 gap-8"
      >
        <div>
          <h2
            class="text-5xl font-black tracking-tighter italic uppercase mb-4"
            data-i18n="home.en.services.heading"
            data-i18n-html
            set:html={page.services.heading}
          />
          <p
            class="text-on-surface-variant max-w-xl font-body italic"
            data-i18n="home.en.services.description"
          >
            {page.services.description}
          </p>
        </div>
        <div class="text-right flex-shrink-0 w-full md:w-64">
          <img
            alt="Mechanical Superiority Workshop"
            class="md:w-64 w-full h-40 object-cover border-r-8 border-primary grayscale hover:grayscale-0 transition-all duration-500"
            src={images.computer}
          />
          <div class="h-2 w-full bg-primary mt-2"></div>
          <p
            class="font-label text-on-surface-variant text-xs mt-1 uppercase tracking-widest"
            data-i18n="home.en.services.workshopLabel"
          >
            {page.services.workshopLabel}
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Service Card 1: ECU STAGE -->
        <div
          class="md:col-span-2 relative group overflow-hidden bg-surface-container-high w-full h-[400px]"
          transition:animate="slide"
        >
          <img
            alt="ECU Tuning Session in-car"
            class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:scale-105 transition-transform duration-700"
            src={images.blueFix}
          />
          <div
            class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent"
          >
          </div>

          <div class="absolute bottom-0 left-0 p-6 md:p-10">
            <span
              class="bg-error-container text-white px-3 py-1 font-bold text-xs mb-2 md:mb-4 inline-block uppercase"
              data-i18n="home.en.services.cards.0.badge"
              >{page.services.cards[0].badge}</span
            >
            <h3
              class="text-3xl md:text-4xl font-black italic mb-2"
              data-i18n="home.en.services.cards.0.title"
            >
              {page.services.cards[0].title}
            </h3>
            <p
              class="text-on-surface-variant max-w-md mb-6"
              data-i18n="home.en.services.cards.0.description"
            >
              {page.services.cards[0].description}
            </p>

            <div class="flex items-center gap-4">
              <span
                class="bg-primary text-on-primary-fixed px-4 py-2 font-black"
                data-i18n="home.en.services.cards.0.price"
                >{page.services.cards[0].price}</span
              >
              <button
                class="text-white flex items-center gap-2 group-hover:translate-x-2 transition-transform"
              >
                <span data-i18n="home.en.services.cards.0.cta"
                  >{page.services.cards[0].cta}</span
                >
                <span class="material-symbols-outlined">arrow_forward</span>
              </button>
            </div>
          </div>
        </div>

        <!-- Service Card 2: 1/4 MILE -->
        <div
          class="bg-surface-container border-t-8 border-primary p-6 md:p-10 flex flex-col justify-between"
        >
          <div>
            <span class="material-symbols-outlined text-primary text-5xl mb-6"
              >speed</span
            >
            <h3
              class="text-3xl font-black italic mb-4"
              data-i18n="home.en.services.cards.1.title"
            >
              {page.services.cards[1].title}
            </h3>
            <p
              class="text-on-surface-variant"
              data-i18n="home.en.services.cards.1.description"
            >
              {page.services.cards[1].description}
            </p>
          </div>

          <div class="mt-12">
            <div
              class="text-primary font-black text-2xl mb-4"
              data-i18n="home.en.services.cards.1.price"
            >
              {page.services.cards[1].price}
            </div>
            <button
              class="w-full bg-white text-black py-4 font-black uppercase hover:bg-primary transition-colors"
              data-i18n="home.en.services.cards.1.cta"
              >{page.services.cards[1].cta}</button
            >
          </div>
        </div>

        <!-- Service Card 3: DYNO -->
        <div
          class="bg-surface-container border-t-8 border-primary p-6 md:p-10 flex flex-col justify-between relative group overflow-hidden"
        >
          <img
            alt="Porsche on dyno lift"
            class="absolute inset-0 w-full h-full object-cover opacity-10 group-hover:opacity-20 transition-opacity"
            src={images.bm}
          />

          <div class="relative z-10">
            <span class="material-symbols-outlined text-primary text-5xl mb-6"
              >precision_manufacturing</span
            >
            <h3
              class="text-3xl font-black italic mb-4"
              data-i18n="home.en.services.cards.2.title"
            >
              {page.services.cards[2].title}
            </h3>
            <p
              class="text-on-surface-variant"
              data-i18n="home.en.services.cards.2.description"
            >
              {page.services.cards[2].description}
            </p>
          </div>

          <div class="mt-12 relative z-10">
            <div
              class="text-primary font-black text-2xl mb-4"
              data-i18n="home.en.services.cards.2.price"
            >
              {page.services.cards[2].price}
            </div>
            <button
              class="w-full bg-white text-black py-4 font-black uppercase hover:bg-primary transition-colors"
              data-i18n="home.en.services.cards.2.cta"
              >{page.services.cards[2].cta}</button
            >
          </div>
        </div>

        <!-- Service Card 4: FORCED INDUCTION -->
        <div
          class="md:col-span-2 relative group overflow-hidden bg-surface-container-high w-full h-[400px]"
        >
          <img
            alt="highly detailed turbocharger system"
            class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:scale-110 transition-transform duration-700"
            src={images.forcedInduction}
          />
          <div
            class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent"
          >
          </div>

          <div class="absolute bottom-0 left-0 p-6 md:p-10">
            <h3
              class="text-3xl md:text-4xl font-black italic mb-2"
              data-i18n="home.en.services.cards.3.title"
            >
              {page.services.cards[3].title}
            </h3>
            <p
              class="text-on-surface-variant max-w-md mb-6"
              data-i18n="home.en.services.cards.3.description"
            >
              {page.services.cards[3].description}
            </p>

            <div class="flex items-center gap-4">
              <span
                class="bg-primary text-on-primary-fixed px-4 py-2 font-black"
                data-i18n="home.en.services.cards.3.price"
                >{page.services.cards[3].price}</span
              >
              <button
                class="text-white flex items-center gap-2 group-hover:translate-x-2 transition-transform"
              >
                <span data-i18n="home.en.services.cards.3.cta"
                  >{page.services.cards[3].cta}</span
                >
                <span class="material-symbols-outlined">arrow_forward</span>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========================================== -->
  <!-- 4. RESULTS BANNER SECTION                  -->
  <!-- ========================================== -->
  <section id="builds" class="py-0 relative overflow-hidden">
    <div class="flex flex-col md:flex-row h-[600px]">
      <div class="relative w-full md:w-1/2 h-full group overflow-hidden">
        <img
          alt="stock dark sports car"
          class="w-full h-full object-cover filter grayscale group-hover:grayscale-0 transition duration-500"
          src={images.blackCar}
        />
        <div
          class="absolute inset-0 bg-black/40 flex items-center justify-center"
        >
          <span
            class="text-8xl font-black opacity-20 italic"
            data-i18n="home.en.results.stockLabel"
            >{page.results.stockLabel}</span
          >
        </div>
        <div
          class="absolute top-0 left-0 bg-white text-black font-black px-6 py-2 uppercase"
          data-i18n="home.en.results.before"
        >
          {page.results.before}
        </div>
      </div>

      <div
        class="relative w-full md:w-1/2 h-full group overflow-hidden border-l-4 border-primary"
      >
        <img
          alt="Custom Purple BMW M5 Build"
          class="w-full h-full object-cover"
          src={images.after}
        />
        <div
          class="absolute inset-0 bg-primary/20 flex items-center justify-center"
        >
          <span
            class="text-8xl font-black opacity-60 italic text-white drop-shadow-2xl"
            >{page.results.afterValue}</span
          >
        </div>
        <div
          class="absolute top-0 right-0 bg-primary text-on-primary-fixed font-black px-6 py-2 uppercase"
          data-i18n="home.en.results.after"
        >
          {page.results.after}
        </div>
      </div>
    </div>
  </section>

  <!-- ========================================== -->
  <!-- 5. URGENT BOOKING WIDGET SECTION           -->
  <!-- ========================================== -->
  <section class="py-24 grid-bg">
    <div class="container mx-auto px-8">
      <div
        class="bg-surface-container border-4 border-primary flex flex-col md:flex-row items-stretch"
      >
        <div
          class="p-6 md:p-12 md:w-1/2 border-b-4 md:border-b-0 md:border-r-4 border-primary"
        >
          <h2
            class="text-4xl md:text-5xl font-black italic mb-4 md:mb-6 leading-tight"
            data-i18n="home.en.booking.heading"
            data-i18n-html
            set:html={page.booking.heading}
          />
          <p
            class="text-xl text-on-surface-variant mb-10 font-body"
            data-i18n="home.en.booking.description"
          >
            {page.booking.description}
          </p>

          <div class="space-y-4">
            <div
              class="flex justify-between items-center bg-surface p-4 border-l-4 border-primary"
            >
              <div
                class="font-black italic"
                data-i18n="home.en.booking.nextAvailableLabel"
              >
                {page.booking.nextAvailableLabel}
              </div>
              <div
                class="text-primary font-bold"
                data-i18n="home.en.booking.nextAvailableValue"
              >
                {page.booking.nextAvailableValue}
              </div>
            </div>
            <div
              class="flex justify-between items-center bg-surface p-4 border-l-4 border-outline-variant"
            >
              <div
                class="font-black italic"
                data-i18n="home.en.booking.locationLabel"
              >
                {page.booking.locationLabel}
              </div>
              <div
                class="text-white font-bold"
                data-i18n="home.en.booking.locationValue"
              >
                {page.booking.locationValue}
              </div>
            </div>
          </div>
        </div>

        <div class="p-6 md:p-12 md:w-1/2 bg-surface-container-highest">
          <div class="grid grid-cols-1 gap-6">
            <div>
              <label
                class="font-label text-xs tracking-widest text-on-surface-variant mb-2 block"
                data-i18n="home.en.booking.selectService"
                >{page.booking.selectService}</label
              >
              <select
                class="w-full bg-surface-container-lowest border-outline-variant text-white p-4 focus:border-primary"
              >
                {
                  page.booking.serviceOptions.map((opt: string) => (
                    <option>{opt}</option>
                  ))
                }
              </select>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label
                  class="font-label text-xs tracking-widest text-on-surface-variant mb-2 block"
                  data-i18n="home.en.booking.fullName"
                  >{page.booking.fullName}</label
                >
                <input
                  class="w-full bg-surface-container-lowest border-outline-variant p-4 focus:border-primary text-white"
                  placeholder={page.booking.fullNamePlaceholder}
                  type="text"
                />
              </div>
              <div>
                <label
                  class="font-label text-xs tracking-widest text-on-surface-variant mb-2 block"
                  data-i18n="home.en.booking.vehicleVin"
                  >{page.booking.vehicleVin}</label
                >
                <input
                  class="w-full bg-surface-container-lowest border-outline-variant p-4 focus:border-primary text-white"
                  placeholder={page.booking.vehicleVinPlaceholder}
                  type="text"
                />
              </div>
            </div>
            <button
              class="w-full bg-primary text-on-primary-fixed py-6 text-2xl font-black uppercase tracking-tighter shadow-[0_8px_16px_rgba(255,143,112,0.3)] hover:scale-[1.02] transition-transform"
              data-i18n="home.en.booking.submitButton"
            >
              {page.booking.submitButton}
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========================================== -->
  <!-- 6. TESTIMONIALS SECTION                    -->
  <!-- ========================================== -->
  <section class="py-24 bg-surface-container-lowest overflow-hidden">
    <div class="container mx-auto px-8">
      <h2
        class="text-3xl md:text-4xl font-black italic mb-10 md:mb-16 border-l-8 border-primary pl-4 md:pl-6"
        data-i18n="home.en.testimonials.heading"
      >
        {page.testimonials.heading}
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {
          page.testimonials.items.map((item: any, i: number) => (
            <div class="bg-surface-container p-6 md:p-10 relative">
              <span class="material-symbols-outlined text-primary/20 text-8xl absolute top-4 right-4">
                format_quote
              </span>
              <p
                class="text-xl italic font-body mb-8 relative z-10"
                data-i18n={`home.en.testimonials.items.${i}.quote`}
              >
                {item.quote}
              </p>
              <div class="flex items-center gap-4 border-t border-outline-variant pt-6">
                <div class="w-12 h-12 bg-primary rounded-sm flex items-center justify-center font-black italic">
                  {item.initials}
                </div>
                <div>
                  <div class="font-black italic">{item.name}</div>
                  <div class="text-xs text-primary font-label uppercase">
                    {item.vehicle}
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
