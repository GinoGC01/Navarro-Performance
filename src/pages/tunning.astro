---
import Layout from "../layouts/Layout.astro";
import config from "../config.json";

const lang = config.meta.defaultLang as keyof typeof config.tunning;
const page = config.tunning[lang];
const images = config.images;
const contact = config.contact;
const schedule = config.schedule;
---

<Layout title={page.title}>
  <!-- ============================================== -->
  <!-- 1. HERO SECTION                                -->
  <!-- ============================================== -->
  <section
    class="relative h-[614px] flex items-center overflow-hidden border-b-4 border-primary"
    transition:animate="fade"
  >
    <div class="absolute inset-0 z-0">
      <img
        alt="High-End Performance Hardware"
        class="w-full h-full object-cover opacity-50 grayscale hover:grayscale-0 transition-all duration-700"
        src={images.hero}
      />
      <div
        class="absolute inset-0 bg-gradient-to-r from-background via-background/70 to-transparent"
      >
      </div>
    </div>
    <div class="relative z-10 px-8 md:px-16 max-w-5xl">
      <div
        class="inline-block bg-primary text-black px-3 py-1 font-headline font-black text-xs tracking-[0.2em] mb-6 uppercase"
        data-i18n="tunning.en.hero.badge"
      >
        {page.hero.badge}
      </div>
      <h1
        class="font-headline font-black text-4xl sm:text-5xl md:text-8xl italic tracking-tighter text-white uppercase leading-[0.9] md:leading-none mb-6"
        data-i18n="tunning.en.hero.heading"
        data-i18n-html
        set:html={page.hero.heading}
      />
      <p
        class="text-on-surface-variant text-lg md:text-xl max-w-2xl font-light leading-relaxed border-l-4 border-primary pl-6"
        data-i18n="tunning.en.hero.description"
      >
        {page.hero.description}
      </p>
    </div>
  </section>

  <!-- ============================================== -->
  <!-- 2. SERVICE CATALOG SECTION                     -->
  <!-- ============================================== -->
  <section class="bg-surface-container-low py-16 md:py-24 px-4 md:px-8">
    <div class="max-w-7xl mx-auto">
      <div
        class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8"
      >
        <div>
          <h2
            class="font-headline font-black text-3xl md:text-4xl uppercase tracking-tighter text-white mb-2"
            data-i18n="tunning.en.catalog.heading"
          >
            {page.catalog.heading}
          </h2>
          <div class="h-1 w-24 bg-primary"></div>
        </div>
        <div
          class="text-on-surface-variant font-label text-sm uppercase tracking-widest"
          data-i18n="tunning.en.catalog.subtitle"
        >
          {page.catalog.subtitle}
        </div>
      </div>

      <!-- Bento Grid Layout -->
      <div
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6"
      >
        <!-- Stage 1 Tune -->
        <div
          class="group bg-surface-container-highest p-6 md:p-8 border-l-4 border-transparent hover:border-primary transition-all duration-300 flex flex-col justify-between shadow-xl relative overflow-hidden"
          transition:animate="slide"
        >
          <div
            class="absolute top-0 right-0 w-48 h-48 -mr-16 -mt-16 opacity-10 group-hover:opacity-30 transition-opacity rotate-12"
          >
            <img
              alt="Tuning Software"
              class="w-full h-full object-cover"
              src={images.computer}
            />
          </div>
          <div>
            <div class="flex justify-between items-start mb-6">
              <span
                class="bg-primary/10 text-primary px-3 py-1 font-headline font-bold text-[10px] tracking-widest border border-primary/20"
                data-i18n="tunning.en.catalog.services.0.badge"
                >{page.catalog.services[0].badge}</span
              >
              <span
                class="text-on-surface-variant font-headline font-bold text-xs"
                >{page.catalog.services[0].number}</span
              >
            </div>
            <h3
              class="font-headline font-black text-2xl text-white mb-4 uppercase"
              data-i18n="tunning.en.catalog.services.0.title"
            >
              {page.catalog.services[0].title}
            </h3>
            <p class="text-on-surface-variant text-sm mb-8 leading-relaxed" data-i18n="tunning.en.catalog.services.0.description">
              {page.catalog.services[0].description}
            </p>
          </div>
          <div class="space-y-6">
            <div
              class="flex justify-between items-center border-t border-outline-variant/30 pt-4"
            >
              <div class="font-headline font-bold text-2xl text-primary">
                {page.catalog.services[0].price}
              </div>
              <div
                class="text-xs font-label text-on-surface-variant uppercase tracking-tighter"
                data-i18n="tunning.en.catalog.services.0.time"
              >
                {page.catalog.services[0].time}
              </div>
            </div>
            <button
              class="w-full bg-surface-container border-2 border-primary text-white py-4 font-headline font-black uppercase tracking-[0.2em] text-xs hover:bg-primary hover:text-black transition-all"
              data-i18n="tunning.en.catalog.services.0.cta"
            >
              {page.catalog.services[0].cta}
            </button>
          </div>
        </div>

        <!-- Stage 2 Tune -->
        <div
          class="group bg-surface-container-highest p-6 md:p-8 border-l-4 border-transparent hover:border-primary transition-all duration-300 flex flex-col justify-between shadow-xl relative overflow-hidden"
        >
          <div
            class="absolute top-0 right-0 w-48 h-48 -mr-16 -mt-16 opacity-10 group-hover:opacity-30 transition-opacity -rotate-12"
          >
            <img
              alt="Precision Interface"
              class="w-full h-full object-cover"
              src={images.blueFix}
            />
          </div>
          <div>
            <div class="flex justify-between items-start mb-6">
              <span
                class="bg-error-container text-on-error-container px-3 py-1 font-headline font-bold text-[10px] tracking-widest"
                data-i18n="tunning.en.catalog.services.1.badge"
                >{page.catalog.services[1].badge}</span
              >
              <span
                class="text-on-surface-variant font-headline font-bold text-xs"
                >{page.catalog.services[1].number}</span
              >
            </div>
            <h3
              class="font-headline font-black text-2xl text-white mb-4 uppercase"
              data-i18n="tunning.en.catalog.services.1.title"
            >
              {page.catalog.services[1].title}
            </h3>
            <p class="text-on-surface-variant text-sm mb-8 leading-relaxed" data-i18n="tunning.en.catalog.services.1.description">
              {page.catalog.services[1].description}
            </p>
          </div>
          <div class="space-y-6">
            <div
              class="flex justify-between items-center border-t border-outline-variant/30 pt-4"
            >
              <div class="font-headline font-bold text-xl text-primary" data-i18n="tunning.en.catalog.services.1.price">
                {page.catalog.services[1].price}
              </div>
              <div
                class="text-xs font-label text-on-surface-variant uppercase tracking-tighter"
                data-i18n="tunning.en.catalog.services.1.time"
              >
                {page.catalog.services[1].time}
              </div>
            </div>
            <button
              class="w-full gradient-button text-on-primary-fixed py-4 font-headline font-black uppercase tracking-[0.2em] text-xs active:scale-95 transition-all"
              data-i18n="tunning.en.catalog.services.1.cta"
            >
              {page.catalog.services[1].cta}
            </button>
          </div>
        </div>

        <!-- Custom Tune -->
        <div
          class="group bg-surface-container-highest p-0 border-l-4 border-transparent hover:border-primary transition-all duration-300 flex flex-col justify-between shadow-xl relative overflow-hidden lg:row-span-2"
        >
          <div class="relative h-64 overflow-hidden">
            <img
              alt="Custom Performance Build"
              class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500 scale-110 group-hover:scale-100"
              src={images.blackCar}
            />
            <div
              class="absolute inset-0 bg-gradient-to-t from-surface-container-highest to-transparent opacity-60"
            >
            </div>
            <div class="absolute top-0 left-0 p-8">
              <span
                class="bg-white text-black px-3 py-1 font-headline font-bold text-[10px] tracking-widest"
                data-i18n="tunning.en.catalog.services.2.badge"
                >{page.catalog.services[2].badge}</span
              >
            </div>
          </div>
          <div class="p-6 md:p-8 flex-grow">
            <div class="flex justify-between items-start mb-6">
              <span
                class="text-on-surface-variant font-headline font-bold text-xs uppercase tracking-widest"
                >Service {page.catalog.services[2].number}</span
              >
            </div>
            <h3
              class="font-headline font-black text-3xl text-white mb-4 uppercase"
              data-i18n="tunning.en.catalog.services.2.title"
            >
              {page.catalog.services[2].title}
            </h3>
            <p class="text-on-surface-variant text-base mb-8 leading-relaxed" data-i18n="tunning.en.catalog.services.2.description">
              {page.catalog.services[2].description}
            </p>

            <ul class="space-y-4 mb-8">
              {page.catalog.services[2].features?.map((feat: string, fi: number) => (
                <li
                  class="flex items-center gap-3 text-xs font-label text-white uppercase"
                >
                  <span class="material-symbols-outlined text-primary text-sm"
                    >check_circle</span
                  >
                  <span data-i18n={`tunning.en.catalog.services.2.features.${fi}`}>{feat}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="p-6 md:p-8 space-y-6 border-t border-outline-variant/30">
            <div class="flex justify-between items-center">
              <div class="font-headline font-bold text-xl text-primary" data-i18n="tunning.en.catalog.services.2.price">
                {page.catalog.services[2].price}
              </div>
              <div
                class="text-xs font-label text-on-surface-variant uppercase tracking-tighter"
                data-i18n="tunning.en.catalog.services.2.time"
              >
                {page.catalog.services[2].time}
              </div>
            </div>
            <button
              class="w-full bg-white text-black py-4 font-headline font-black uppercase tracking-[0.2em] text-xs hover:bg-primary transition-all"
              data-i18n="tunning.en.catalog.services.2.cta"
            >
              {page.catalog.services[2].cta}
            </button>
          </div>
        </div>

        <!-- Transmission Tune -->
        <div
          class="group bg-surface-container-highest p-6 md:p-8 border-l-4 border-transparent hover:border-primary transition-all duration-300 flex flex-col justify-between shadow-xl relative"
        >
          <div>
            <div class="flex justify-between items-start mb-6">
              <span
                class="bg-primary/10 text-primary px-3 py-1 font-headline font-bold text-[10px] tracking-widest border border-primary/20"
                data-i18n="tunning.en.catalog.services.3.badge"
                >{page.catalog.services[3].badge}</span
              >
              <span
                class="text-on-surface-variant font-headline font-bold text-xs"
                >{page.catalog.services[3].number}</span
              >
            </div>
            <h3
              class="font-headline font-black text-2xl text-white mb-4 uppercase"
              data-i18n="tunning.en.catalog.services.3.title"
            >
              {page.catalog.services[3].title}
            </h3>
            <p class="text-on-surface-variant text-sm mb-8 leading-relaxed" data-i18n="tunning.en.catalog.services.3.description">
              {page.catalog.services[3].description}
            </p>
          </div>
          <div class="space-y-6">
            <div
              class="flex justify-between items-center border-t border-outline-variant/30 pt-4"
            >
              <div class="font-headline font-bold text-2xl text-primary">
                {page.catalog.services[3].price}
              </div>
              <div
                class="text-xs font-label text-on-surface-variant uppercase tracking-tighter"
                data-i18n="tunning.en.catalog.services.3.time"
              >
                {page.catalog.services[3].time}
              </div>
            </div>
            <button
              class="w-full bg-surface-container-high border-2 border-outline-variant text-white py-4 font-headline font-black uppercase tracking-[0.2em] text-xs hover:border-primary transition-all"
              data-i18n="tunning.en.catalog.services.3.cta"
            >
              {page.catalog.services[3].cta}
            </button>
          </div>
        </div>

        <!-- DPF & EGR -->
        <div
          class="group bg-surface-container-highest p-6 md:p-8 border-l-4 border-transparent hover:border-primary transition-all duration-300 flex flex-col justify-between shadow-xl relative"
        >
          <div>
            <div class="flex justify-between items-start mb-6">
              <span
                class="bg-error-container text-on-error-container px-3 py-1 font-headline font-bold text-[10px] tracking-widest uppercase"
                data-i18n="tunning.en.catalog.services.4.badge"
                >{page.catalog.services[4].badge}</span
              >
              <span
                class="text-on-surface-variant font-headline font-bold text-xs"
                >{page.catalog.services[4].number}</span
              >
            </div>
            <h3
              class="font-headline font-black text-2xl text-white mb-4 uppercase"
            >
              {page.catalog.services[4].title}
            </h3>
            <p class="text-on-surface-variant text-sm mb-8 leading-relaxed" data-i18n="tunning.en.catalog.services.4.description">
              {page.catalog.services[4].description}
            </p>
          </div>
          <div class="space-y-6">
            <div
              class="flex justify-between items-center border-t border-outline-variant/30 pt-4"
            >
              <div class="font-headline font-bold text-2xl text-primary">
                {page.catalog.services[4].price}
              </div>
              <div
                class="text-xs font-label text-on-surface-variant uppercase tracking-tighter"
                data-i18n="tunning.en.catalog.services.4.time"
              >
                {page.catalog.services[4].time}
              </div>
            </div>
            <button
              class="w-full bg-surface-container-high border-2 border-outline-variant text-white py-4 font-headline font-black uppercase tracking-[0.2em] text-xs hover:border-primary transition-all"
              data-i18n="tunning.en.catalog.services.4.cta"
            >
              {page.catalog.services[4].cta}
            </button>
          </div>
        </div>

        <!-- Pre-tune Consultation -->
        <div
          class="group bg-surface-container p-6 md:p-8 border-2 border-outline-variant/20 flex flex-col justify-between hover:bg-surface-bright transition-colors relative overflow-hidden"
        >
          <div
            class="absolute inset-0 opacity-10 group-hover:opacity-20 transition-opacity"
          >
            <img
              alt="Consultation Specialist"
              class="w-full h-full object-cover grayscale"
              src={images.computer}
            />
          </div>
          <div class="relative z-10">
            <h3
              class="font-headline font-black text-xl text-white mb-2 uppercase italic"
            >
              <span>{page.catalog.services[5].number}</span> // <span data-i18n="tunning.en.catalog.services.5.title">{page.catalog.services[5].title}</span>
            </h3>
            <p
              class="text-on-surface-variant text-xs mb-6 uppercase tracking-wider"
              data-i18n="tunning.en.catalog.services.5.description"
            >
              {page.catalog.services[5].description}
            </p>
          </div>
          <div class="flex justify-between items-end relative z-10">
            <div>
              <div
                class="text-xs font-label text-on-surface-variant uppercase mb-1"
                data-i18n="tunning.en.catalog.services.5.priceLabel"
              >
                {page.catalog.services[5].priceLabel}
              </div>
              <div class="font-headline font-bold text-xl text-white">
                {page.catalog.services[5].price}
              </div>
            </div>
            <button
              class="bg-primary text-black px-4 py-2 font-headline font-bold text-[10px] tracking-widest uppercase"
              data-i18n="tunning.en.catalog.services.5.cta"
              >{page.catalog.services[5].cta}</button
            >
          </div>
        </div>

        <!-- Pops & Flames -->
        <div
          class="group bg-surface-container p-6 md:p-8 border-2 border-outline-variant/20 flex flex-col justify-between hover:bg-surface-bright transition-colors"
        >
          <div>
            <h3
              class="font-headline font-black text-xl text-white mb-2 uppercase italic"
            >
              <span>{page.catalog.services[6].number}</span> // <span data-i18n="tunning.en.catalog.services.6.title">{page.catalog.services[6].title}</span>
            </h3>
            <p
              class="text-on-surface-variant text-xs mb-6 uppercase tracking-wider"
              data-i18n="tunning.en.catalog.services.6.description"
            >
              {page.catalog.services[6].description}
            </p>
          </div>
          <div class="flex justify-between items-end">
            <div>
              <div
                class="text-xs font-label text-on-surface-variant uppercase mb-1"
                data-i18n="tunning.en.catalog.services.6.priceLabel"
              >
                {page.catalog.services[6].priceLabel}
              </div>
              <div class="font-headline font-bold text-xl text-white">
                {page.catalog.services[6].price}
              </div>
            </div>
            <button
              class="bg-primary text-black px-4 py-2 font-headline font-bold text-[10px] tracking-widest uppercase"
              data-i18n="tunning.en.catalog.services.6.cta"
              >{page.catalog.services[6].cta}</button
            >
          </div>
        </div>

        <!-- Pops & Bangs -->
        <div
          class="group bg-surface-container p-6 md:p-8 border-2 border-outline-variant/20 flex flex-col justify-between hover:bg-surface-bright transition-colors"
        >
          <div>
            <h3
              class="font-headline font-black text-xl text-white mb-2 uppercase italic"
            >
              <span>{page.catalog.services[7].number}</span> // <span data-i18n="tunning.en.catalog.services.7.title">{page.catalog.services[7].title}</span>
            </h3>
            <p
              class="text-on-surface-variant text-xs mb-6 uppercase tracking-wider"
              data-i18n="tunning.en.catalog.services.7.description"
            >
              {page.catalog.services[7].description}
            </p>
          </div>
          <div class="flex justify-between items-end">
            <div>
              <div
                class="text-xs font-label text-on-surface-variant uppercase mb-1"
                data-i18n="tunning.en.catalog.services.7.priceLabel"
              >
                {page.catalog.services[7].priceLabel}
              </div>
              <div class="font-headline font-bold text-xl text-white">
                {page.catalog.services[7].price}
              </div>
            </div>
            <button
              class="bg-primary text-black px-4 py-2 font-headline font-bold text-[10px] tracking-widest uppercase"
              data-i18n="tunning.en.catalog.services.7.cta"
              >{page.catalog.services[7].cta}</button
            >
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================== -->
  <!-- 3. TECHNICAL SHOWCASE SECTION                  -->
  <!-- ============================================== -->
  <section
    class="bg-background py-16 md:py-24 px-4 md:px-8 border-y-4 border-outline-variant/20 relative overflow-hidden"
  >
    <div
      class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-16 items-center"
    >
      <div class="lg:w-1/2">
        <img
          alt="Dyno Room"
          class="w-full h-[500px] object-cover grayscale brightness-50 contrast-125 border-4 border-primary"
          src={images.bm}
        />
      </div>
      <div class="lg:w-1/2 space-y-8">
        <h2
          class="font-headline font-black text-4xl md:text-5xl uppercase italic tracking-tighter leading-tight text-white"
          data-i18n="tunning.en.showcase.heading"
          data-i18n-html
          set:html={page.showcase.heading}
        />
        <p class="text-on-surface-variant leading-relaxed" data-i18n="tunning.en.showcase.description">
          {page.showcase.description}
        </p>

        <div class="grid grid-cols-2 gap-4">
          {page.showcase.stats.map((stat: any, i: number) => (
            <div class="bg-surface-container-high p-6 border-l-2 border-primary">
              <div class="text-primary font-headline font-black text-3xl mb-1">
                {stat.value}
              </div>
              <div
                class="text-on-surface-variant font-label text-[10px] tracking-[0.2em] uppercase"
                data-i18n={`tunning.en.showcase.stats.${i}.label`}
              >
                {stat.label}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================== -->
  <!-- 4. LOCATION & HOURS SECTION                   -->
  <!-- ============================================== -->
  <section class="bg-surface-container-low py-20 px-4 md:px-8 border-t-4 border-surface-container">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Modern Interactive Map Container -->
        <div class="relative group h-[400px] md:h-[500px] bg-surface-container-highest border-4 border-surface-container overflow-hidden shadow-2xl">
          <div class="absolute inset-0 bg-primary/10 pointer-events-none z-10 group-hover:bg-transparent transition-colors duration-500"></div>
          <iframe 
            src={contact.mapEmbed}
            class="w-full h-full border-0 grayscale invert contrast-125 brightness-75 hover:grayscale-0 hover:invert-0 hover:brightness-100 transition-all duration-700" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade">
          </iframe>
          <div class="absolute bottom-4 left-4 z-20">
            <a 
              href={contact.mapDirections}
              target="_blank" 
              class="bg-primary text-black px-6 py-3 font-headline font-black text-xs uppercase tracking-widest hover:scale-105 transition-transform inline-block shadow-xl"
              data-i18n="tunning.en.location.getDirections"
            >
              {page.location.getDirections}
            </a>
          </div>
        </div>

        <!-- Details & Schedule -->
        <div class="space-y-10">
          <div>
            <h2 class="font-headline font-black text-5xl uppercase italic tracking-tighter text-white mb-6"
              data-i18n="tunning.en.location.heading"
              data-i18n-html
              set:html={page.location.heading}
            />
            <div class="h-1 w-24 bg-primary mb-8"></div>
            
            <div class="space-y-4">
              <a href={`tel:${contact.phoneFull}`} class="flex items-center gap-4 text-white hover:text-primary transition-colors group">
                <span class="material-symbols-outlined text-primary group-hover:scale-110 transition-transform">phone_in_talk</span>
                <span class="font-headline font-bold text-xl">{contact.phone}</span>
              </a>
              <a href={`mailto:${contact.email}`} class="flex items-center gap-4 text-white hover:text-primary transition-colors group">
                <span class="material-symbols-outlined text-primary group-hover:scale-110 transition-transform">mail</span>
                <span class="font-headline font-bold text-lg md:text-xl">{contact.email}</span>
              </a>
            </div>
          </div>

          <div class="bg-surface-container-highest p-8 border-l-4 border-primary">
            <h3 class="font-headline font-black text-sm uppercase tracking-[0.2em] text-on-surface-variant mb-6"
              data-i18n="tunning.en.location.operationalWindow"
            >
              {page.location.operationalWindow}
            </h3>
            <div class="space-y-3">
              {schedule.map((item) => (
                <div class="flex justify-between items-center border-b border-white/5 pb-2">
                  <span class="font-headline font-bold text-white uppercase text-sm" data-schedule-day>{item.day[lang]}</span>
                  <span class={`font-label text-sm ${item.closed ? 'text-primary font-black italic' : 'text-on-surface-variant'}`} {...(item.closed ? { "data-schedule-closed": "" } : {})}>
                    {typeof item.hours === 'string' ? item.hours : (typeof item.hours === 'object' ? item.hours[lang] : item.hours)}
                  </span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
